<Window x:Class="InternetSpeedTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:InternetSpeedTest.ViewModels"
        Title="Тест скорости интернета" 
        Height="700" Width="1200"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Padding" Value="22,14"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#7C4DFF"/>
            <Setter Property="BorderBrush" Value="#7C4DFF"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.3" BlurRadius="5"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ProgressBar" x:Key="CircularProgress" BasedOn="{StaticResource MaterialDesignCircularProgressBar}">
            <Setter Property="Foreground" Value="#FF4081"/>
            <Setter Property="Background" Value="#424242"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Value" Value="{Binding Progress}"/>
        </Style>
        <Style TargetType="RadioButton" BasedOn="{StaticResource MaterialDesignRadioButton}">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{Binding TextColor}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="SpeedGauge" TargetType="Border">
            <Setter Property="Background" Value="{Binding CardBackground}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="25"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#7C4DFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="3" Opacity="0.4" BlurRadius="8"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Margin="15">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{Binding SelectedBackgroundColor}" Offset="0"/>
                <GradientStop Color="{Binding GradientEndColor}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border CornerRadius="30" BorderBrush="#7C4DFF" BorderThickness="3" Effect="{StaticResource MaterialDesignElevationShadow4}">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Тест скорости интернета"
                               FontSize="36"
                               Foreground="{Binding TextColor}"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,25,0,35"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <RadioButton Content="Тёмная" IsChecked="{Binding DarkTheme, Mode=TwoWay}" GroupName="Theme"/>
                        <RadioButton Content="Серая" IsChecked="{Binding GrayTheme, Mode=TwoWay}" GroupName="Theme"/>
                        <RadioButton Content="Светлая" IsChecked="{Binding LightTheme, Mode=TwoWay}" GroupName="Theme"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Margin="30">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="Скачивание: " Foreground="{Binding TextColor}" FontSize="26" FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding DownloadSpeed}" Foreground="#FF4081" FontSize="26" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="Загрузка: " Foreground="{Binding TextColor}" FontSize="26" FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding UploadSpeed}" Foreground="#FF4081" FontSize="26" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="Пинг: " Foreground="{Binding TextColor}" FontSize="26" FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding Ping}" Foreground="#FF4081" FontSize="26" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Сервер: " Foreground="{Binding TextColor}" FontSize="26" FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding Server}" Foreground="#FF4081" FontSize="26" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource SpeedGauge}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Текущая скорость" Foreground="{Binding TextColor}" FontSize="22" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <ProgressBar Value="{Binding CurrentSpeedProgress}" Style="{StaticResource MaterialDesignCircularProgressBar}" Width="120" Height="120" Foreground="#FF4081" Background="Purple"/>
                            <TextBlock Text="{Binding CurrentDownloadSpeed}" Foreground="#FF4081" FontSize="28" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <Button Content="Начать тест" Command="{Binding StartTestCommand}" Height="50"/>
                    <Button Content="Экспорт результатов" Command="{Binding ExportCommand}" Height="50"/>
                    <Button Content="Закрыть" Command="{Binding CloseCommand}" Height="50"/>
                </StackPanel>
                <ProgressBar Grid.Row="3" Style="{StaticResource CircularProgress}" 
                             IsIndeterminate="{Binding IsTesting}" 
                             Visibility="{Binding IsTesting, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)" From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ProgressBar.Triggers>
                    <ProgressBar.RenderTransform>
                        <RotateTransform CenterX="35" CenterY="35"/>
                    </ProgressBar.RenderTransform>
                </ProgressBar>
            </Grid>
        </Border>
    </Border>
</Window>